<% content_for :page_title, "Data manual" %>

<header class="datagovuk-data-manual-hero">
  <h1 class="govuk-heading-xl datagovuk-heading-xl govuk-!-margin-bottom-4">
    Data manual
  </h1>
  <p class="govuk-body datagovuk-body">
    A guide to working with data in government and the public sector
  </p>
</header>

<div class="govuk-width-container">
  <section class="govuk-!-margin-bottom-6">
    <div class="govuk-grid-row">
      <div class="govuk-grid-column-full">
        <%= render partial: "v2/components/data_manual_grid", locals: {
          items: [
            {
              title: "Who this manual is for",
              url: "#",
              body: "Find out if this manual can help you and why it's important.",
              icon: "user",
            },
            {
              title: "Data management",
              url: "#",
              body: "Understand data roles and responsibilities, and how to manage data quality.",
              icon: "database",
            },
            {
              title: "Data standards",
              url: "#",
              body: "A range of standards for improving how data is used across government.",
              icon: "document",
            },
            {
              title: "Security",
              url: "#",
              body: "Strategies, policies and guidance to make your service safer.",
              icon: "padlock",
            },
            {
              title: "Data protection and privacy",
              url: "#",
              body: "How to comply with the Data Protection Act 2018 and UK GDPR.",
              icon: "shield",
            },
            {
              title: "Data sharing",
              url: "#",
              body: "Frameworks and guides about sharing data between government organisations.",
              icon: "sharing",
            },
            {
              title: "AI and data-driven technologies",
              url: "#",
              body: "How to build APIs in government and improve API standards.",
              icon: "stars",
            },
            {
              title: "General guidance",
              url: "#",
              body: "Where to start when you're creating a new public service.",
              icon: "open-book",
            },
          ]
        } %>
      </div>
    </div>
  </section>

  <section class="govuk-!-margin-bottom-9">
    <div class="govuk-grid-row">
      <div class="govuk-grid-column-two-thirds">
        <%= render partial: "v2/components/feedback" %>
      </div>
    </div>
  </section>

  <section class="govuk-!-margin-bottom-9">
    <div class="govuk-grid-row">

      <div class="govuk-grid-column-one-half">
        <div class="datagovuk-data-manual-card ">
          <%= image_tag "v2/icons/phone", class: "datagovuk-data-manual-card__icon", alt: "" %>
          <h2 class="govuk-body datagovuk-body">
            <a href="#" class="govuk-link datagovuk-link datagovuk-!-colour-dark-green">Get in touch</a>
          </h2>
          <p class="govuk-body datagovuk-body govuk-!-margin-bottom-0 datagovuk-!-colour-dark-green">
            We’d love your feedback. Is this manual useful? Can we improve it?
          </p>
        </div>
      </div>

      <div class="govuk-grid-column-one-half">
        <div class="datagovuk-data-manual-card datagovuk-data-manual-card--secondary">
          <%= image_tag "v2/icons/community", class: "datagovuk-data-manual-card__icon", alt: "" %>
          <h2 class="govuk-body datagovuk-body">
            <a href="#" class="govuk-link datagovuk-link datagovuk-!-colour-dark-pink">Join a data community</a>
          </h2>
          <p class="govuk-body datagovuk-body govuk-!-margin-bottom-0 datagovuk-!-colour-dark-pink">
            Find Slack channels, events and other ways to connect with data practitioners.
          </p>
        </div>
      </div>

    </div>
  </section>
</div>
