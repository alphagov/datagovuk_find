<% content_for :page_title do %>Sorry, there is a problem with the service<% end %>

<div class="govuk-width-container datagovuk-width-container govuk-!-margin-top-9">
  <div class="govuk-grid-row">
    <div class="govuk-grid-column-two-thirds">
      <h1 class="govuk-heading-l datagovuk-heading-l">Sorry, there is a problem with the service</h1>
      <p class="govuk-body datagovuk-body">
        Try again later.
      </p>
      <p class="govuk-body datagovuk-body">
        If the issue persists, please use the <a href="https://www.gov.uk/contact/govuk" class="govuk-link datagovuk-link datagovuk-link--secondary">GOV.UK support form</a> and mention that it’s about data.gov.uk.
      </p>
    </div>
  </div>
</div>
