<%# locals:
subtitle: string,
description_html: string
value: string/number
comparison_html: string
trend: :up or :down
value_change: string/number
percent_change: string/number
side_class: string
%>

<% is_trending_up = (trend.to_sym == :up) %>
<% trend_class = is_trending_up ? "datagovuk-split-chart__change--up" : "datagovuk-split-chart__change--down" %>

<div class="govuk-grid-column-one-half datagovuk-split-chart__col <%= side_class %>">
    <h2 class="govuk-heading-m datagovuk-heading-m govuk-!-margin-bottom-2"><%= subtitle %>:</h3>
    <p class="govuk-body datagovuk-body">
        <%= simple_format(description_html, {}, wrapper_tag: nil) %>
    </p>
    <h2 class="govuk-heading-xl datagovuk-heading-xl datagovuk-split-chart__value govuk-!-margin-bottom-2">
        <%= number_with_delimiter(value) %>
    </h2>
    <p class="govuk-body govuk-!-margin-bottom-6">
        <%= simple_format(comparison_html, {}, wrapper_tag: nil) %>
    </p>

    <section class="datagovuk-split-chart__change <%= trend_class %> govuk-!-margin-bottom-0">
        <section class="govuk-section datagovuk-section <%= is_trending_up ? "datagovuk-trendup" : "datagovuk-trenddown" %>">
            <span class="datagovuk-split-chart__arrow" aria-hidden="true">
                <% if is_trending_up %>
                    <%= image_tag("v2/small_up_arrow.png") %>
                <% else %>
                    <%= image_tag("v2/small_down_arrow.png") %>
                <% end %>
            </span>
            <p class="datagovuk-split-chart__change-value govuk-body datagovuk-body"><%= is_trending_up ? "+" : "-" %><%= value_change %></p>
            <p class="datagovuk-split-chart__change-value-prc govuk-body datagovuk-body">(<%= percent_change %>%)</p>
        </section>
    </section>
</div>