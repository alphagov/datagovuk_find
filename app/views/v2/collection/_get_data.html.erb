<section class="datagovuk-link datagovuk-section" aria-label="Get the data links">
    <section class="datagovuk-section">
        <h3 class="govuk-heading-m datagovuk-heading-m">Get the data</h3>

        <ul class="govuk-list datagovuk-list">
            <% if local_assigns[:dataset] %>
                <li>
                    <a class="govuk-link datagovuk-link" href="<%= local_assigns[:dataset] %>">Dataset</a>
                </li>
            <% end %>
        </ul>
        <%= link_to local_assigns[:website] || "#", role: 'button', class: 'govuk-button datagovuk-button', rel: %w(nofollow) do %>
            More information <span class='datagovuk-right-arrow'>&#8594;</span>
        <% end %>
        <ul class="govuk-list datagovuk-list">
            <% if local_assigns[:api_link] %>
                <li>
                    <a class="govuk-link datagovuk-link"href="<%= local_assigns[:api_link] %>">API documentation</a>
                </li>
            <% end %>
            <% if local_assigns[:datasets_download_link].present? %>
                <li>
                    <a class="govuk-link datagovuk-link"href="<%= local_assigns[:datasets_download_link] %>">Download the datasets</a>
                </li>
            <% end %>
        </ul>
    </section>

    <section class="datagovuk-section">
        <% if local_assigns[:page_last_updated] %>
            <p class="govuk-body datagovuk-body">The page was last updated <%= local_assigns[:page_last_updated] %></p>
        <% end %>
    </section>
</section>